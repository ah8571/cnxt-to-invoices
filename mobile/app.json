{
  "expo": {
    "name": "cnxt to invoices",
    "slug": "cnxt-to-invoice-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "cnxt-to-invoices",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f1ea"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "to.cnxt.invoices",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "ios": {
      "bundleIdentifier": "to.cnxt.invoices"
    },
    "extra": {
      "eas": {
        "projectId": "9255692f-c4e4-4999-89a8-4e0de5f14377"
      }
    },
    "plugins": [
      "expo-web-browser",
      "@sentry/react-native"
    ]
  }
}
